# NeuroSupport — Environment Variables
# Copy this file to .env and fill in your Supabase project values.
# Never commit .env to git.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → anon / public key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI API key — enables GPT-4o-mini adaptive coaching in practice sessions
# Get it from: https://platform.openai.com/api-keys
# If left empty, the app falls back to hardcoded coaching messages (still works)
VITE_OPENAI_API_KEY=sk-...
